# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Diagnostic reports (https://nodejs.org/api/report.html)
report.[0-9]*.[0-9]*.[0-9]*.[0-9]*.json

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Dependency directories
node_modules/
backend/node_modules/
frontend/node_modules/

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# dotenv environment variable files
.env
.env.*
!.env.example

# Mac OS files
.DS_Store

# IDEs and Editors
.idea/
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

# Backend specific
backend/uploads/*
!backend/uploads/.gitkeep
backend/coverage/

# Frontend specific (Vite/Vue)
frontend/dist/
frontend/dist-ssr/
frontend/.vite/
frontend/coverage/

# Vercel / Netlify / etc
.vercel/
.netlify/

